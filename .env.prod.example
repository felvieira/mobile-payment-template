# ============================================================
# PAYMENT HUB - Production Environment Template
#
# Copy to .env.prod.local or configure these values in your deploy
# platform secrets. Do not commit real secret values.
# ============================================================

NODE_ENV=production

# APP
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXTAUTH_URL=https://your-domain.com
CRON_SECRET=<set-in-secret-manager>

# DATABASE
DATABASE_URL=<set-in-secret-manager>

# STRIPE
# Account-level values may be reused if this app uses the same Stripe account.
# Product price IDs and webhook secrets are per app/product and must be created for this deployment.
STRIPE_SECRET_KEY=<set-in-secret-manager>
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=<public-publishable-key>
STRIPE_WEBHOOK_SECRET=<set-after-creating-this-app-webhook>
STRIPE_AI_PRICE_ID=<this-app-price-id>
STRIPE_AI_ANNUAL_PRICE_ID=<this-app-annual-price-id>

# MERCADOPAGO
# Access token/public key may be reused if this app uses the same Mercado Pago account.
# Webhook secret is per webhook endpoint.
MERCADOPAGO_ACCESS_TOKEN=<set-in-secret-manager>
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=<public-key>
MERCADOPAGO_WEBHOOK_SECRET=<set-after-creating-this-app-webhook>

# ABACATE PAY
ABACATE_PAY_ENV=prod
ABACATE_PAY_DEV_API_KEY=<set-in-secret-manager>
ABACATE_PAY_PROD_API_KEY=<set-in-secret-manager>
ABACATE_PAY_WEBHOOK_SECRET=<set-after-creating-this-app-webhook>

# GOOGLE PLAY IAP
GOOGLE_PLAY_PACKAGE_NAME=<android-package-name>
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=<set-in-secret-manager>
RTDN_WEBHOOK_SECRET=<set-in-secret-manager>
# Product IDs — create in Play Console > Monetização > Assinaturas
NEXT_PUBLIC_GOOGLE_PLAY_PRODUCT_ID=app_premium_monthly      # PER-APP
NEXT_PUBLIC_GOOGLE_PLAY_ANNUAL_PRODUCT_ID=app_premium_annual # PER-APP

# GOOGLE OAUTH / NEXTAUTH
GOOGLE_CLIENT_ID=<oauth-client-id>
GOOGLE_CLIENT_SECRET=<set-in-secret-manager>
NEXTAUTH_SECRET=<set-in-secret-manager>

# FCM PUSH NOTIFICATIONS
FCM_SERVICE_ACCOUNT_JSON=<set-in-secret-manager>
NOTIFICATIONS_ADMIN_TOKEN=<set-in-secret-manager>

# ADMIN
ADMIN_EMAILS=admin@example.com
