# ============================================================
# PAYMENT HUB — Environment Variables
#
# REUSABLE = account-level key, same across all your apps
# PER-APP  = must be created/configured for each new app
# ============================================================

# -----------------------------------------------------------
# DATABASE (PER-APP)
# -----------------------------------------------------------
# Local dev: docker compose up -d
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/payment_hub

# -----------------------------------------------------------
# STRIPE (REUSABLE: secret + publishable key)
#         PER-APP:  price IDs + webhook secret)
# -----------------------------------------------------------
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxx                      # REUSABLE
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx     # REUSABLE
# Dashboard > Products > Create product > Copy price ID
STRIPE_AI_PRICE_ID=price_xxx                       # PER-APP
STRIPE_AI_ANNUAL_PRICE_ID=price_xxx                # PER-APP
# Dashboard > Webhooks > Add endpoint > your-domain/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_xxx                    # PER-APP

# -----------------------------------------------------------
# MERCADOPAGO (REUSABLE: access token + public key)
#              PER-APP:  webhook secret)
# -----------------------------------------------------------
# Dashboard: https://www.mercadopago.com.br/developers/panel/app
MERCADOPAGO_ACCESS_TOKEN=TEST-xxx                  # REUSABLE
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=TEST-xxx        # REUSABLE
MERCADOPAGO_WEBHOOK_SECRET=                        # PER-APP

# -----------------------------------------------------------
# ABACATE PAY — PIX (REUSABLE: dev key; PER-APP: prod key + webhook)
# -----------------------------------------------------------
# Dashboard: https://dash.abacatepay.com
ABACATE_PAY_ENV=dev                                # dev | prod
ABACATE_PAY_DEV_API_KEY=abc_dev_xxx               # REUSABLE
ABACATE_PAY_PROD_API_KEY=abc_prod_xxx             # PER-APP
ABACATE_PAY_WEBHOOK_SECRET=                        # PER-APP

# -----------------------------------------------------------
# GOOGLE PLAY IAP (PER-APP — all tied to package name)
# -----------------------------------------------------------
# Must match app.config.ts packageName
GOOGLE_PLAY_PACKAGE_NAME=com.payment_hub.demo     # PER-APP
# Google Play Console > Setup > API access > Service account JSON
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=                 # PER-APP
# Random strong string; used in Pub/Sub Push URL as ?secret=<value>
RTDN_WEBHOOK_SECRET=                               # PER-APP

# -----------------------------------------------------------
# GOOGLE OAUTH / NEXTAUTH (PER-APP)
# -----------------------------------------------------------
# Google Cloud Console > APIs > Credentials > OAuth 2.0 Client
# Authorized origins: your-domain.com + localhost:3000
# Authorized redirects: your-domain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com   # PER-APP
GOOGLE_CLIENT_SECRET=GOCSPX-xxx                   # PER-APP
# openssl rand -base64 32
NEXTAUTH_SECRET=                                   # PER-APP
NEXTAUTH_URL=http://localhost:3000                 # PER-APP

# -----------------------------------------------------------
# FCM PUSH NOTIFICATIONS (PER-APP)
# -----------------------------------------------------------
# Firebase Console > Project Settings > Service accounts > Generate new private key
FCM_SERVICE_ACCOUNT_JSON=                          # PER-APP
# openssl rand -base64 32 — gates POST /api/notifications/send
NOTIFICATIONS_ADMIN_TOKEN=                        # PER-APP

# -----------------------------------------------------------
# APP
# -----------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
ADMIN_EMAILS=admin@example.com,owner@example.com
CRON_SECRET=                                       # openssl rand -base64 32
